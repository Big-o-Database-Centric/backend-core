# Node environment
NODE_ENV=production
PORT=3000

# SQL Server connection (exact names required by the backend)
SQL_SERVER=your-vps-host.com
SQL_DATABASE=database_centric_platform
SQL_USER=your-db-user
SQL_PASSWORD=your-db-password
SQL_PORT=1433
SQL_SERVER_ENCRYPT=true
SQL_SERVER_TRUST_SERVER_CERT=false

# CORS
CORS_ORIGIN=https://big-o.andrescortes.dev

# Auth / OAuth (REQUIRED: the app crashes on startup if any of these is missing,
# because the Google/GitHub strategies read them via getOrThrow at bootstrap)
AUTH_SECRET=generate-with-openssl-rand-base64-32
PUBLIC_BASE_URL=https://big-o.andrescortes.dev
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
