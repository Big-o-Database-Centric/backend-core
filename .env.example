# ==================================
# Backend Core - Auth Configuration
# ==================================

# Node environment (development | test | production)
NODE_ENV=development

# NextAuth.js v5
# Generate: openssl rand -base64 32
AUTH_SECRET=your-32-char-min-secret-key-here

# Trust the host (required for OAuth callbacks)
AUTH_TRUST_HOST=true

# ==================================
# OAuth Providers (Tu compañero los llena)
# ==================================

# Google OAuth
# 1. Crear proyecto en Google Cloud Console
# 2. Habilitar Google+ API
# 3. Crear credentials OAuth 2.0
# 4. Añadir authorized redirect URI: https://tu-dominio.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth
# 1. Crear OAuth App en GitHub Settings > Developer settings > OAuth Apps
# 2. Authorization callback URL: https://tu-dominio.com/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ==================================
# SQL Server Connection (VPS)
# ==================================

SQL_SERVER_HOST=your-vps-host.com
SQL_SERVER_PORT=1433
SQL_SERVER_USER=your-db-user
SQL_SERVER_PASSWORD=your-db-password
SQL_SERVER_DATABASE=database_centric_platform

# SQL Server encryption (true/false)
SQL_SERVER_ENCRYPT=true
SQL_SERVER_TRUST_SERVER_CERT=false

# Connection pool settings
SQL_SERVER_POOL_MAX=10
SQL_SERVER_REQUEST_TIMEOUT=30000

# ==================================
# Debugging (opcional en desarrollo)
# ==================================

# Enable NextAuth debug logs
# DEBUG=next-auth*